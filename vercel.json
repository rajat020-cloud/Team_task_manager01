{
  "version": 2,
  "installCommand": "npm install",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "builds": [
        {
          "src": "frontend/package.json",
          "use": "@vercel/static-build",
          "config": {
            "distDir": "dist"
          }
        }
      ],
      "routes": [
        {
          "src": "/api/(.*)",
          "dest": "/api/index.ts"
        },
        {
          "handle": "filesystem"
        },
        {
          "src": "/.*",
          "dest": "frontend/dist/index.html"
        }
  ]
}
