{
  "version": 2,
  "nodejs": "20.x",
  "installCommand": "npm install --workspaces --ignore-scripts",
  "buildCommand": "npm run build:all",
  "outputDirectory": "frontend/dist",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/backend/src/index.ts"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
