{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build:all",
  "builds": [
    { "src": "frontend/package.json", "use": "@vercel/static-build" },
    { "src": "backend/src/index.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/src/index.ts" }
  ]
}
